<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.sop.SopProcessMapper">

    <resultMap type="com.ruoyi.system.domain.sop.SopProcess" id="SopProcessResult">
        <id     property="sopId"       column="sop_id"       />
        <result property="sopCode"     column="sop_code"     />
        <result property="sopName"     column="sop_name"     />
        <result property="productId"   column="product_id"   />
        <result property="productCode" column="product_code" />
        <result property="productName" column="product_name" />
        <result property="version"     column="version"      />
        <result property="status"      column="status"       />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectSopProcessVo">
        select p.sop_id, p.sop_code, p.sop_name, p.product_id, pr.product_code, pr.product_name,
               p.version, p.status, p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from sop_process p
        left join sop_product pr on pr.product_id = p.product_id
    </sql>

    <select id="selectSopProcessList" parameterType="com.ruoyi.system.domain.sop.SopProcess" resultMap="SopProcessResult">
        <include refid="selectSopProcessVo"/>
        <where>
            <if test="sopCode != null and sopCode != ''">and p.sop_code like concat('%', #{sopCode}, '%')</if>
            <if test="sopName != null and sopName != ''">and p.sop_name like concat('%', #{sopName}, '%')</if>
            <if test="productId != null">and p.product_id = #{productId}</if>
            <if test="productCode != null and productCode != ''">and pr.product_code like concat('%', #{productCode}, '%')</if>
            <if test="status != null and status != ''">and p.status = #{status}</if>
        </where>
        order by p.sop_id desc
    </select>

    <select id="selectSopProcessAll" resultMap="SopProcessResult">
        <include refid="selectSopProcessVo"/>
        order by p.sop_code asc
    </select>

    <select id="selectSopProcessBySopId" parameterType="Long" resultMap="SopProcessResult">
        <include refid="selectSopProcessVo"/>
        where p.sop_id = #{sopId}
    </select>

    <insert id="insertSopProcess" parameterType="com.ruoyi.system.domain.sop.SopProcess" useGeneratedKeys="true" keyProperty="sopId">
        insert into sop_process
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sopCode != null and sopCode != ''">sop_code,</if>
            <if test="sopName != null and sopName != ''">sop_name,</if>
            <if test="productId != null">product_id,</if>
            <if test="version != null and version != ''">version,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sopCode != null and sopCode != ''">#{sopCode},</if>
            <if test="sopName != null and sopName != ''">#{sopName},</if>
            <if test="productId != null">#{productId},</if>
            <if test="version != null and version != ''">#{version},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
        </trim>
    </insert>

    <update id="updateSopProcess" parameterType="com.ruoyi.system.domain.sop.SopProcess">
        update sop_process
        <set>
            <if test="sopCode != null and sopCode != ''">sop_code = #{sopCode},</if>
            <if test="sopName != null and sopName != ''">sop_name = #{sopName},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="version != null and version != ''">version = #{version},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where sop_id = #{sopId}
    </update>

    <delete id="deleteSopProcessBySopId" parameterType="Long">
        delete from sop_process where sop_id = #{sopId}
    </delete>

    <delete id="deleteSopProcessBySopIds" parameterType="Long">
        delete from sop_process where sop_id in
        <foreach collection="array" item="sopId" open="(" separator="," close=")">
            #{sopId}
        </foreach>
    </delete>
</mapper>
