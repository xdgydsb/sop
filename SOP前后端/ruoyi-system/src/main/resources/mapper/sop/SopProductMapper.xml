<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.sop.SopProductMapper">

    <resultMap type="com.ruoyi.system.domain.sop.SopProduct" id="SopProductResult">
        <id     property="productId"    column="product_id"    />
        <result property="productCode"  column="product_code"  />
        <result property="productName"  column="product_name"  />
        <result property="productModel" column="product_model" />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectSopProductVo">
        select product_id, product_code, product_name, product_model, status, create_by, create_time, update_by, update_time, remark
        from sop_product
    </sql>

    <select id="selectSopProductList" parameterType="com.ruoyi.system.domain.sop.SopProduct" resultMap="SopProductResult">
        <include refid="selectSopProductVo"/>
        <where>
            <if test="productCode != null and productCode != ''">and product_code like concat('%', #{productCode}, '%')</if>
            <if test="productName != null and productName != ''">and product_name like concat('%', #{productName}, '%')</if>
            <if test="productModel != null and productModel != ''">and product_model like concat('%', #{productModel}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by product_id desc
    </select>

    <select id="selectSopProductAll" resultMap="SopProductResult">
        <include refid="selectSopProductVo"/>
        order by product_code asc
    </select>

    <select id="selectSopProductByProductId" parameterType="Long" resultMap="SopProductResult">
        <include refid="selectSopProductVo"/>
        where product_id = #{productId}
    </select>

    <insert id="insertSopProduct" parameterType="com.ruoyi.system.domain.sop.SopProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into sop_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="productCode != null and productCode != ''">product_code,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="productModel != null">product_model,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="productCode != null and productCode != ''">#{productCode},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="productModel != null">#{productModel},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
        </trim>
    </insert>

    <update id="updateSopProduct" parameterType="com.ruoyi.system.domain.sop.SopProduct">
        update sop_product
        <set>
            <if test="productCode != null and productCode != ''">product_code = #{productCode},</if>
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="productModel != null">product_model = #{productModel},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where product_id = #{productId}
    </update>

    <delete id="deleteSopProductByProductId" parameterType="Long">
        delete from sop_product where product_id = #{productId}
    </delete>

    <delete id="deleteSopProductByProductIds" parameterType="Long">
        delete from sop_product where product_id in
        <foreach collection="array" item="productId" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>
</mapper>
